---
layout: false
permalink: /
---
{%- set totalGroups = 0 %}
{%- for cat in collections.categories %}
  {%- set totalGroups = totalGroups + cat.data.groupCount %}
{%- endfor %}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/head.njk" %}
  <title>Vancouver Community Directory — {{ totalGroups }}+ Groups, Clubs & Meetups (2026)</title>
  <meta name="description" content="{{ site.description }}">
  <meta property="og:title" content="Vancouver Community Directory — Find Your People">
  <meta property="og:description" content="{{ site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}/">
  <meta property="og:image" content="{{ site.url }}/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Vancouver Community Directory — Find Your People">
  <meta name="twitter:description" content="{{ site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/og-image.png">
  <link rel="canonical" href="{{ site.url }}/">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "url": "{{ site.url }}",
    "description": "{{ site.description }}",
    "areaServed": {
      "@type": "City",
      "name": "Vancouver",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "BC",
        "addressCountry": "CA"
      }
    },
    "publisher": {
      "@type": "Person",
      "name": "Patrick Bollenbach",
      "url": "https://bollenbach.ca"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Community Categories in Vancouver",
    "numberOfItems": {{ collections.categories.length }},
    "itemListElement": [
      {%- for cat in collections.categories %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ cat.data.title }}",
        "url": "{{ site.url }}/{{ cat.fileSlug }}/"{% if cat.data.groupCount %},
        "numberOfItems": {{ cat.data.groupCount }}{% endif %}
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
  </script>
</head>
<body class="homepage">
<a href="#main-content" class="skip-link">Skip to content</a>
{% include "partials/topbar.njk" %}

<main id="main-content">
  <div class="hp-hero">
    <div class="hp-hero-inner">
      <h1 class="hp-lede">Find your people in Vancouver.</h1>
      <p class="hp-desc">{{ totalGroups }}+ groups across {{ collections.categories.length }} categories. Run clubs, supper clubs, philosophy circles, maker spaces, and more. Browse, click through, show up.</p>
      <div class="hp-search">
        <input type="text" id="homepage-group-search" class="hp-search-input" placeholder="Search {{ totalGroups }}+ groups — try &quot;hiking&quot;, &quot;chess&quot;, &quot;supper club&quot;…" autocomplete="off" data-umami-event="homepage-search">
      </div>
      <div class="hp-actions">
        <a href="/start-here/" data-umami-event="click-start-here" data-umami-event-source="homepage">New to Vancouver? Start here &rarr;</a>
        <span class="hp-sep">&middot;</span>
        <a href="/submit/" data-umami-event="click-submit-cta" data-umami-event-source="homepage">Add a group</a>
        <span class="hp-sep">&middot;</span>
        <a href="/blog/start-a-group/" data-umami-event="click-start-group" data-umami-event-source="homepage">Start a group</a>
        <span class="hp-sep">&middot;</span>
        <button type="button" onclick="goRandom()" data-umami-event="click-surprise" data-umami-event-source="homepage">Surprise me</button>
        <span class="hp-sep">&middot;</span>
        <button type="button" onclick="sharePage('homepage', this)" data-umami-event="click-share" data-umami-event-source="homepage">Share this site</button>
        <span class="hp-sep">&middot;</span>
        <a href="#categories" class="hp-jump">All categories &darr;</a>
      </div>
    </div>
    <div id="search-results" class="search-results" style="display:none"></div>
  </div>

  <div id="homepage-browse-content">

  {%- if recentGroups.length > 0 %}
  <section class="hp-section">
    <p class="hp-section-title">Recently added</p>
    <div class="recent-groups">
      {%- for group in recentGroups %}
      <a href="/{{ group.categorySlug }}/#{{ group.name | slugify }}" class="recent-group" data-umami-event="click-recent-group">
        <span class="recent-group-meta"><span class="recent-group-tag">New this week</span> <span class="recent-group-cat">{{ group.categoryTitle }}</span></span>
        <span class="recent-group-name">{{ group.name }}</span>
        <span class="recent-group-desc">{{ group.description | truncate(80) }}</span>
      </a>
      {%- endfor %}
    </div>
  </section>
  {%- endif %}

  <section class="hp-section" id="categories">
    <p class="hp-section-title">Browse {{ totalGroups }}+ groups</p>
    {%- for group in groups %}
    <div class="hp-cat-group">
      <p class="hp-cat-group-label">{{ group.label | ampEscape | safe }}</p>
      <div class="hp-cat-grid">
        {%- for cat in collections.categories %}
        {%- if cat.data.group == group.key %}
        <a href="/{{ cat.fileSlug }}/" class="hp-cat-card" data-umami-event="click-category" data-umami-event-category="{{ cat.fileSlug }}">
          <span class="hp-cat-name">{{ cat.data.title }}</span>
          {% if cat.data.groupCount > 0 %}<span class="hp-cat-count">{{ cat.data.groupCount }}</span>{% endif %}
        </a>
        {%- endif %}
        {%- endfor %}
      </div>
    </div>
    {%- endfor %}
  </section>

  <section class="hp-newsletter">
    <div class="hp-newsletter-inner">
      <p class="hp-newsletter-heading">Every Friday in your inbox</p>
      <p class="hp-newsletter-desc">New groups, community picks, and one thing to do this weekend.</p>
      <form class="newsletter-form hp-newsletter-form" data-umami-event="newsletter-signup">
        <input type="email" class="newsletter-input" placeholder="your@email.com" required aria-label="Email address">
        <button type="submit" class="newsletter-btn">Subscribe</button>
      </form>
      <span class="newsletter-status"></span>
    </div>
  </section>

  <footer class="hp-footer">
    <div class="builder-card">
      <div class="builder-header">
        <div class="builder-avatar" aria-hidden="true"></div>
        <div>
          <span class="builder-label">Built by</span>
          <strong><a href="https://bollenbach.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-bollenbach" data-umami-event-source="builder-card">Patrick Bollenbach</a></strong>
        </div>
      </div>
      <p class="builder-bio">I make community tools in Vancouver. <a href="mailto:vancouver@bolle.co" data-umami-event="click-contact-email">Get in touch</a>.</p>
      <div class="builder-links">
        <a href="https://runclubs.ca?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-runclubs" data-umami-event-source="builder-card">runclubs.ca</a>
        <span class="builder-link-sep">&middot;</span>
        <a href="https://cuento.app?ref=vancouvercommunity" target="_blank" rel="noopener noreferrer" data-umami-event="click-cuento" data-umami-event-source="builder-card">cuento.app</a>
      </div>
    </div>
    <div class="hp-footer-links">
      <a href="/submit/">Submit a group</a>
      <span>&middot;</span>
      <a href="/blog/start-a-group/">Start a group</a>
      <span>&middot;</span>
      <a href="/start-here/">New to Vancouver</a>
      <span>&middot;</span>
      <a href="/blog/">Blog</a>
      <span>&middot;</span>
      <a href="/about/">About</a>
      <span>&middot;</span>
      <button type="button" onclick="goRandom()">Surprise me</button>
    </div>
    <div class="hp-footer-views">
      <span id="homepage-total-views"></span>
    </div>
  </footer>

  </div><!-- end #homepage-browse-content -->

  <script>
  var _searchGroups = [
  {%- for cat in collections.categories -%}
    {%- for item in cat.data.groupItems -%}
    {n:"{{ item.name | replace('"', '\\"') }}",d:"{{ item.description | replace('"', '\\"') | truncate(120) }}",c:"{{ cat.data.title }}",s:"{{ cat.fileSlug }}",id:"{{ item.name | slugify }}",u:"{{ item.url | replace('"', '\\"') }}"},
    {%- endfor -%}
  {%- endfor -%}
  ];
  </script>
</main>
{% include "partials/scripts.njk" %}
</body>
</html>
